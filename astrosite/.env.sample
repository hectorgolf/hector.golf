# Copy this file to .env and replace placeholder values.
# npm test uses env-cmd and requires a .env file to exist.
# Note: test/unit includes integration tests that require working WiseGolf + Teetime credentials.

# --- Required for WiseGolf integration tests and handicap workflows ---
WISEGOLF_USERNAME=your_wisegolf_username
WISEGOLF_PASSWORD=your_wisegolf_password

# --- Required for update-player-biographies workflow (this is the GCP API key) ---
ASTROSITE_API_KEY=your_backend_function_bearer_token
# Optional: set to true/1 to print extra biography generation debug output.
DEBUG_GENAI_BIOGRAPHY=false

# --- Required for update-leaderboards workflow ---
GITHUB_ACCESS_TOKEN=ghp_your_github_token

# --- Required for Google Sheets access in leaderboard workflow ---
# Must be valid JSON because code parses this value with JSON.parse().
# Keep it on one line.
GOOGLE_CREDENTIALS={"type":"service_account","project_id":"your-project-id","private_key_id":"your-private-key-id","private_key":"-----BEGIN PRIVATE KEY-----\\nREPLACE_ME\\n-----END PRIVATE KEY-----\\n","client_email":"service-account@your-project-id.iam.gserviceaccount.com","client_id":"1234567890"}
